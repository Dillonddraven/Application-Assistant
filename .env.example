# Copy to .env and fill in for whichever provider you want to use.
# job-apply reads this file at startup.

# --- Choose ONE provider ---
LLM_PROVIDER=openai
# Valid values: openai | deepseek | openai-compat | anthropic

# === OpenAI (default) ===
OPENAI_API_KEY=sk-...

# === DeepSeek ===
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...
# Optional model overrides:
# JOB_APPLY_MODEL_EXTRACT=deepseek-chat
# JOB_APPLY_MODEL_TAILOR=deepseek-chat
# JOB_APPLY_MODEL_DEEP=deepseek-reasoner

# === Anthropic ===
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# JOB_APPLY_MODEL_TAILOR=claude-sonnet-4-5
# JOB_APPLY_MODEL_DEEP=claude-opus-4

# === Any OpenAI-compatible endpoint (Ollama, LM Studio, vLLM, Together, ...) ===
# LLM_PROVIDER=openai-compat
# LLM_BASE_URL=http://localhost:11434/v1   # Ollama default
# LLM_API_KEY=ollama                       # Ollama doesn't need a real key
# JOB_APPLY_MODEL_EXTRACT=qwen2.5:7b
# JOB_APPLY_MODEL_TAILOR=qwen2.5:14b
# JOB_APPLY_MODEL_DEEP=qwen2.5:32b
